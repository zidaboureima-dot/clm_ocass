import 'package:flutter/material.dart';
import 'package:firebase_core/firebase_core.dart';
import 'package:firebase_auth/firebase_auth.dart';
import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:intl/date_symbol_data_local.dart';
import 'firebase_options.dart';
import 'services/auth_service.dart';
import 'theme/app_theme.dart';
import 'screens/signalement_screen.dart';
import 'screens/connexion_screen.dart';
import 'screens/admin/admin_shell.dart';
import 'screens/point_focal/point_focal_shell.dart';
import 'screens/tableau_bord_public_screen.dart';

Future<void> main() async {
  WidgetsFlutterBinding.ensureInitialized();
  await Firebase.initializeApp(options: DefaultFirebaseOptions.currentPlatform);
  await initializeDateFormatting('fr', null);
  runApp(const ClmOcassApp());
}

class ClmOcassApp extends StatelessWidget {
  const ClmOcassApp({super.key});
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'CLM/OCASS Guinee',
      theme: AppTheme.theme,
      debugShowCheckedModeBanner: false,
      initialRoute: '/',
      routes: {
        '/': (context) => const _RootRouter(),
      },
    );
  }
}

class _RootRouter extends StatelessWidget {
  const _RootRouter();
  @override
  Widget build(BuildContext context) {
    return StreamBuilder<User?>(
      stream: FirebaseAuth.instance.authStateChanges(),
      builder: (context, snap) {
        if (snap.connectionState == ConnectionState.waiting) {
          return const Scaffold(body: Center(child: CircularProgressIndicator(color: AppColors.vertPrimaire)));
        }
        if (snap.data == null) return const _HomePublique();
        return FutureBuilder<ProfilUtilisateur?>(
          future: AuthService().profilCourant(),
          builder: (context, profSnap) {
            if (profSnap.connectionState == ConnectionState.waiting) {
              return const Scaffold(body: Center(child: CircularProgressIndicator(color: AppColors.vertPrimaire)));
            }
            final profil = profSnap.data;
            if (profil == null || profil.role == RoleUtilisateur.inconnu) return const _HomePublique();
            if (profil.estAdmin) return AdminShell(profil: profil);
            if (profil.estPointFocal) return PointFocalShell(profil: profil);
            return const _HomePublique();
          },
        );
      },
    );
  }
}

class _HomePublique extends StatelessWidget {
  const _HomePublique();

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: SafeArea(
        child: Column(
          children: [
            Container(
              width: double.infinity,
              padding: const EdgeInsets.fromLTRB(20, 28, 20, 24),
              color: const Color(0xFF085041),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Row(children: [
                    Container(
                      width: 36, height: 36,
                      decoration: BoxDecoration(color: const Color(0xFFE1F5EE), borderRadius: BorderRadius.circular(8)),
                      child: const Icon(Icons.shield_outlined, size: 20, color: Color(0xFF085041)),
                    ),
                    const SizedBox(width: 10),
                    const Text('CLM/OCASS Guinee', style: TextStyle(color: Colors.white, fontSize: 16, fontWeight: FontWeight.w500)),
                  ]),
                  const SizedBox(height: 16),
                  const Text('Suivi dirige par les communautes',
                      style: TextStyle(color: Colors.white, fontSize: 22, fontWeight: FontWeight.w600, height: 1.2)),
                  const SizedBox(height: 6),
                  const Text('Signalez un dysfonctionnement des services de sante en toute confidentialite.',
                      style: TextStyle(color: Colors.white70, fontSize: 13, height: 1.5)),
                ],
              ),
            ),
            StreamBuilder<DocumentSnapshot>(
              stream: FirebaseFirestore.instance.collection('clm_stats_publiques').doc('global').snapshots(),
              builder: (context, snap) {
                final data = snap.data?.data() as Map<String, dynamic>? ?? {};
                final total = data['total'] ?? 0;
                final mois = data['total_mois'] ?? 0;
                final traites = data['total_traites'] ?? 0;
                final loading = !snap.hasData;
                return Container(
                  color: Colors.white,
                  padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 14),
                  child: Row(children: [
                    _metrique('Total', loading ? '...' : '$total', const Color(0xFF1D9E75), Icons.inventory_2_outlined),
                    Container(width: 0.5, height: 44, color: const Color(0xFFD3D1C7)),
                    _metrique('Traites', loading ? '...' : '$traites', const Color(0xFF185FA5), Icons.check_circle_outline),
                    Container(width: 0.5, height: 44, color: const Color(0xFFD3D1C7)),
                    _metrique('Ce mois', loading ? '...' : '$mois', const Color(0xFFBA7517), Icons.calendar_month_outlined),
                  ]),
                );
              },
            ),
            Container(height: 0.5, color: const Color(0xFFD3D1C7)),
            Expanded(
              child: SingleChildScrollView(
                padding: const EdgeInsets.all(20),
                child: Column(children: [
                  const SizedBox(height: 8),
                  Container(
                    padding: const EdgeInsets.all(14),
                    decoration: BoxDecoration(
                      color: const Color(0xFFE1F5EE),
                      borderRadius: BorderRadius.circular(10),
                      border: Border.all(color: const Color(0xFF1D9E75).withOpacity(0.3)),
                    ),
                    child: const Row(children: [
                      Icon(Icons.shield_outlined, color: Color(0xFF085041), size: 22),
                      SizedBox(width: 12),
                      Expanded(child: Text('Anonymat garanti. Aucune donnee vous identifiant collectee')
                          style: TextStyle(fontSize: 13, color: Color(0xFF085041), height: 1.4))),
                    ]),
                  ),
                  const SizedBox(height: 20),
                  ElevatedButton.icon(
                    onPressed: () => Navigator.push(context, MaterialPageRoute(builder: (_) => const SignalementScreen())),
                    icon: const Icon(Icons.warning_amber_outlined, size: 20),
                    label: const Text('Faire un signalement'),
                    style: ElevatedButton.styleFrom(backgroundColor: const Color(0xFF1D9E75),
                        minimumSize: const Size(double.infinity, 52),
                        textStyle: const TextStyle(fontSize: 16, fontWeight: FontWeight.w500)),
                  ),
                  const SizedBox(height: 12),
                  OutlinedButton.icon(
                    onPressed: () => Navigator.push(context, MaterialPageRoute(builder: (_) => const TableauBordPublicScreen())),
                    icon: const Icon(Icons.bar_chart_outlined, size: 18),
                    label: const Text('Voir le tableau de bord public'),
                  ),
                  const SizedBox(height: 12),
                  OutlinedButton.icon(
                    onPressed: () => Navigator.push(context, MaterialPageRoute(builder: (_) => const ConnexionScreen())),
                    icon: const Icon(Icons.lock_outline, size: 18),
                    label: const Text('Acces admin / point focal'),
                  ),
                  const SizedBox(height: 32),
                  Text('Ce dispositif est mis en oeuvre dans le cadre du CLM/OCASS Guinee - Propulse par SapSapServices.',
                      textAlign: TextAlign.center,
                      style: TextStyle(fontSize: 11, color: Colors.grey.withOpacity(0.7), height: 1.5)),
                ]),
              ),
            ),
          ],
        ),
      ),
    );
  }

  Widget _metrique(String label, String valeur, Color couleur, IconData icon) {
    return Expanded(child: Column(children: [
      Icon(icon, size: 18, color: couleur),
      const SizedBox(height: 4),
      Text(valeur, style: TextStyle(fontSize: 20, fontWeight: FontWeight.w600, color: couleur)),
      const SizedBox(height: 2),
      Text(label, style: const TextStyle(fontSize: 11, color: Colors.grey), textAlign: TextAlign.center),
    ]));
  }
}
